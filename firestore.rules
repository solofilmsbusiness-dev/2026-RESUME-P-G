rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: portfolios
    // Document ID: {userId}
    // Fields:
    //   - userId: string (required) - The owner's UID
    //   - assets: map (required) - Portfolio assets data
    //   - updatedAt: timestamp (optional) - Last update time
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "SoloFilmsBusiness@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidPortfolio(data) {
      return data.keys().hasAll(['userId', 'assets']) &&
             data.userId is string &&
             data.userId.size() < 128 &&
             data.assets is map &&
             data.assets.size() < 50 && // Limit number of assets
             (!('updatedAt' in data) || data.updatedAt is timestamp);
    }

    match /portfolios/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();

      match /assets/{assetId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isOwner(userId) || isAdmin();
      }
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin();
    }
  }
}
